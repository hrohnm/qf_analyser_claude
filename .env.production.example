# ==============================================
# QF Analyser – Production Environment
# Kopiere diese Datei als .env auf den Server
# und trage deine echten Werte ein!
# ==============================================

# Datenbank
DB_PASSWORD=DEIN_SICHERES_PASSWORT

# API-Football (api-football.com)
API_FOOTBALL_KEY=DEIN_API_KEY
API_DAILY_LIMIT=7500

# AI Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# CORS – deine Domain(s), kommagetrennt
CORS_ORIGINS=https://deine-domain.de

# Umgebung
ENVIRONMENT=production
